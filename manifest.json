{
  "manifest_version": 3,
  "name": "Bulwark",
  "version": "0.1.4",
  "description": "Block ads, trackers, and distracting sites.",
  "permissions": ["declarativeNetRequest", "declarativeNetRequestFeedback", "storage", "scripting", "tabs", "alarms", "webNavigation", "contextMenus", "privacy"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "action": { "default_popup": "src/popup/popup.html", "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png" } },
  "options_page": "src/options/options.html",
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["src/content/cosmetic.js"], "run_at": "document_start" }
  ],
  "web_accessible_resources": [
    { "resources": ["src/content/picker.js", "src/content/selector.js", "src/content/cosmetic-select.js", "pages/blocked.html"], "matches": ["<all_urls>"] }
  ],
  "commands": {
    "toggle-site": { "suggested_key": { "default": "Ctrl+Shift+B", "mac": "Command+Shift+B" }, "description": "Toggle blocking on the current site" }
  },
  "declarative_net_request": {
    "rule_resources": [
      { "id": "ads", "enabled": true, "path": "rules/easylist.json" },
      { "id": "privacy", "enabled": true, "path": "rules/easyprivacy.json" }
    ]
  }
}
